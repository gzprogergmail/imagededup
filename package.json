{
  "name": "imagededup",
  "version": "1.0.4",
  "description": "Electron desktop app for image duplicate detection with fast and slow passes.",
  "keywords": [
    "electron",
    "image",
    "deduplication",
    "duplicates",
    "perceptual-hash"
  ],
  "homepage": "https://github.com/gzprogergmail/imagededup#readme",
  "bugs": {
    "url": "https://github.com/gzprogergmail/imagededup/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gzprogergmail/imagededup.git"
  },
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/main/main/main.js",
  "bin": {
    "imagededup": "./bin/imagededup.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "docs",
    "README.md",
    "LICENSE",
    "package.json",
    "tsconfig*.json",
    "vite.config.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "coverage:check": "node scripts/check-coverage.mjs",
    "e2e:fixtures": "node scripts/generate-test-images.mjs tests/.generated/e2e",
    "lint": "eslint .",
    "package": "npm run package:dir",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "package:release": "npm run release",
    "prepack": "npm run build",
    "perf": "vitest run --config vitest.performance.config.ts",
    "release": "npm run build && electron-builder --publish never",
    "release:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "release:win": "npm run build && electron-builder --win nsis portable --publish never",
    "start": "npm run build && electron .",
    "test": "npm run lint && npm run test:unit && npm run test:e2e && npm run perf && npm run coverage:check",
    "test:e2e": "npm run build && npm run e2e:fixtures && playwright test",
    "test:unit": "vitest run --coverage"
  },
  "build": {
    "appId": "com.local.imagededup",
    "productName": "ImageDedup",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.5.0",
    "electron": "^41.3.0",
    "fast-glob": "^3.3.3",
    "imghash": "^1.1.0",
    "photoswipe": "^5.4.4",
    "sharp": "^0.34.4",
    "ssim.js": "^3.5.0",
    "zod": "^4.1.12"
  }
}
